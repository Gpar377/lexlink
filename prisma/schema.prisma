generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      String   @default("CITIZEN") // CITIZEN | LAWYER
  phone     String?
  state     String?
  city      String?
  createdAt DateTime @default(now())

  lawyerProfile   LawyerProfile?
  cases           Case[]
  messages        CaseMessage[]
  documents       Document[]
  timelineEvents  TimelineEvent[]
}

model LawyerProfile {
  id              String   @id @default(uuid())
  userId          String   @unique
  specializations String   // JSON array of category names
  barCouncilId    String?
  state           String
  city            String?
  yearsExperience Int      @default(0)
  verified        Boolean  @default(false)
  bio             String?
  rating          Float    @default(0)

  user        User               @relation(fields: [userId], references: [id])
  assignments LawyerAssignment[]
}

model LegalCategory {
  id               String @id @default(uuid())
  name             String @unique
  icon             String
  description      String
  proceduralSteps  String // JSON array
  documentChecklist String // JSON array
  urgencyRules     String // JSON object
  cases            Case[]
}

model Case {
  id              String   @id @default(uuid())
  userId          String
  categoryId      String
  title           String
  description     String
  stateOfIncident String
  city            String?
  status          String   @default("OPEN") // OPEN | NEEDS_LAWYER | IN_PROGRESS | RESOLVED | CLOSED
  isUrgent        Boolean  @default(false)
  lawyerMode      String   @default("SELF") // SELF | LOCAL_ONLY | PRIMARY_ONLY | BOTH
  aiSummary       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user        User               @relation(fields: [userId], references: [id])
  category    LegalCategory      @relation(fields: [categoryId], references: [id])
  messages    CaseMessage[]
  documents   Document[]
  timeline    TimelineEvent[]
  assignments LawyerAssignment[]
}

model CaseMessage {
  id          String   @id @default(uuid())
  caseId      String
  senderId    String?
  senderRole  String   // AI | CITIZEN | LAWYER
  senderName  String?
  content     String
  messageType String   @default("GUIDANCE") // GUIDANCE | QUESTION | ANSWER | NOTE | ACTION | DOCUMENT_ANALYSIS
  timestamp   DateTime @default(now())

  case   Case  @relation(fields: [caseId], references: [id])
  sender User? @relation(fields: [senderId], references: [id])
}

model Document {
  id           String   @id @default(uuid())
  caseId       String
  uploadedById String
  documentType String
  fileName     String
  filePath     String
  fileSize     Int?
  aiSummary    String?
  aiDeadlines  String?  // JSON array of extracted deadlines
  status       String   @default("UPLOADED") // UPLOADED | ANALYZED | VERIFIED
  uploadedAt   DateTime @default(now())

  case       Case @relation(fields: [caseId], references: [id])
  uploadedBy User @relation(fields: [uploadedById], references: [id])
}

model TimelineEvent {
  id               String   @id @default(uuid())
  caseId           String
  createdById      String?
  eventDescription String
  eventType        String   @default("NOTE") // NOTE | DOCUMENT | STATUS_CHANGE | LAWYER_ASSIGNED | HEARING | ACTION | AI_GUIDANCE
  metadata         String?  // JSON for extra data
  timestamp        DateTime @default(now())

  case      Case  @relation(fields: [caseId], references: [id])
  createdBy User? @relation(fields: [createdById], references: [id])
}

model LawyerAssignment {
  id         String   @id @default(uuid())
  caseId     String
  lawyerId   String
  roleType   String   @default("LOCAL") // PRIMARY | LOCAL | CONSULTANT
  status     String   @default("PENDING") // PENDING | ACCEPTED | REJECTED | WITHDRAWN
  assignedAt DateTime @default(now())

  case   Case          @relation(fields: [caseId], references: [id])
  lawyer LawyerProfile @relation(fields: [lawyerId], references: [id])
}
